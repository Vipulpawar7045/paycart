<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>PayCart — Order Confirmed!</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('partials/navbar') %>
<main class="container">
  <div class="success-container">
    <div class="success-card">
      <div class="success-icon">✅</div>
      <h2>Payment Successful!</h2>
      <p>Thank you for your order. Your order has been confirmed.</p>
      <div class="order-meta">
        <div class="meta-row"><span>Order ID</span><strong>#<%= orderId %></strong></div>
        <div class="meta-row"><span>Amount Paid</span><strong>₹<%= Number(total).toFixed(2) %></strong></div>
        <div class="meta-row"><span>Status</span><span class="status-paid">PAID</span></div>
      </div>
      <div class="success-actions">
        <a href="/orders" class="btn-checkout">View My Orders</a>
        <a href="/" class="btn-add">Continue Shopping</a>
      </div>
    </div>
  </div>
</main>
</body>
</html>
