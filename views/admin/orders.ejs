<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>PayCart — All Orders</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/navbar') %>
<main class="container">
  <div class="admin-header">
    <h2>📋 All Orders</h2>
    <a href="/admin" class="btn-add">← Products</a>
  </div>
  <table class="cart-table">
    <thead>
      <tr><th>Order ID</th><th>Customer</th><th>Email</th><th>Total</th><th>Status</th><th>Date</th></tr>
    </thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.user_name %></td>
          <td><%= o.email %></td>
          <td>₹<%= Number(o.total_amount).toFixed(2) %></td>
          <td><span class="order-status status-<%= o.status.toLowerCase() %>"><%= o.status %></span></td>
          <td><%= new Date(o.created_at).toLocaleDateString('en-IN') %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>
</body>
</html>
