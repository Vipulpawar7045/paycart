<nav class="navbar">
  <a class="brand" href="/">🛒 PayCart</a>

  <form class="search-form" action="/" method="GET">
    <input type="text" name="search" placeholder="Search products..." value="<%= typeof search !== 'undefined' ? search : '' %>"/>
    <button type="submit">Search</button>
  </form>

  <div class="nav-links">
    <% if (user) { %>
      <a href="/cart">🛍️ Cart</a>
      <a href="/orders">📋 Orders</a>
      <% if (user.role === 'ADMIN') { %>
        <a href="/admin" class="admin-link">⚙️ Admin</a>
      <% } %>
      <span class="nav-user">Hi, <%= user.name.split(' ')[0] %></span>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register" class="btn-register">Register</a>
    <% } %>
  </div>
</nav>
